# ─── Database (Supabase Postgres) ─────────────────────────────────────────────
# From Supabase > Project Settings > Database > Connection string (project ulbfaxhsbbckotcbmslk)
# postgresql://postgres:[YOUR-PASSWORD]@db.ulbfaxhsbbckotcbmslk.supabase.co:5432/postgres
# (use pooler version for Netlify prod: port 6543 + postgres.ulbfaxhsbbckotcbmslk user)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ulbfaxhsbbckotcbmslk.supabase.co:5432/postgres"

# ─── Supabase (project: ulbfaxhsbbckotcbmslk) ─────────────────────────────────
# IMPORTANT: For REAL login (OTP) to work on prod:
# 1. Use exact values from Supabase Dashboard > Project Settings > API
# 2. Set the SAME vars in Netlify env (with NEXT_PUBLIC_ prefix for client)
# 3. Update Supabase Auth > URL config with https://wacke.live + /auth/callback
# 4. Trigger full redeploy after env changes (NEXT_PUBLIC_* are build-time)
NEXT_PUBLIC_SUPABASE_URL="https://ulbfaxhsbbckotcbmslk.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ─── Mux Live (primary native streaming) ──────────────────────────────────────
# Dashboard: https://dashboard.mux.com → Access Tokens (Video)
MUX_TOKEN_ID="your-mux-token-id"
MUX_TOKEN_SECRET="your-mux-token-secret"
# Webhooks → https://wacke.live/api/webhooks/mux
# Events: video.live_stream.active, video.live_stream.idle, video.live_stream.disconnected
MUX_WEBHOOK_SECRET="your-mux-webhook-signing-secret"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
# Sign Kick/Twitch platform sessions (required in production)
WACKE_SESSION_SECRET="long-random-string-at-least-32-chars"
# Never enable on public hosts:
# ALLOW_LEGACY_MOCK_AUTH=true
# ALLOW_TOKEN_MOCK_CHECKOUT=true
# BETTING_ENABLED=true

# ─── Grok xAI (get key from https://console.x.ai) ─────────────────────────────
XAI_API_KEY="xai-your-key-here"
